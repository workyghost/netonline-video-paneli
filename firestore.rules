rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /firms/{firmId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email != null;
    }

    match /videos/{videoId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email != null;
    }

    match /screens/{screenId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      // Email kullanıcıları (admin) tüm alanları güncelleyebilir.
      // Anonim kullanıcılar (player) sadece heartbeat alanlarını güncelleyebilir.
      allow update: if request.auth != null &&
        (request.auth.token.email != null ||
         request.resource.data.diff(resource.data).affectedKeys()
           .hasOnly(['lastSeen', 'status', 'currentVideoId', 'currentVideoTitle']));
      allow delete: if request.auth != null && request.auth.token.email != null;
    }

    match /playlists/{playlistId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.email != null;
    }
  }
}
